# No API keys required — all data sources are free and open.
# Copy this file to .env and adjust if needed.

# Server-side URL the Next.js proxy uses to reach the FastAPI backend.
# - In docker-compose: http://backend:8000 (internal container network)
# - Local dev (frontend only): http://localhost:8000
# The browser always calls relative /api/* paths — this value never leaks to the client.
API_URL=http://localhost:8000
